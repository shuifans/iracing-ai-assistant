# === 运行环境 ===
# 应用运行环境 (development | test | production)
NODE_ENV=development
# 应用公网 URL
APP_BASE_URL=http://localhost:3000
# HTTP 监听端口
PORT=3000
# 时区
TZ=Asia/Shanghai

# === 数据路径 ===
# SQLite 数据库文件路径
DATABASE_PATH=/data/db/app.sqlite
# 持久化数据根目录
DATA_ROOT=/data
# Wiki Git worktree 路径
WIKI_ROOT=/data/md-wiki

# === Wiki Git ===
# Wiki Git 远程仓库地址（可选，未配置时仅本地提交）
WIKI_GIT_REMOTE=
# Wiki Git 分支
WIKI_GIT_BRANCH=main

# === 安全密钥 ===
# JWT Access Token 签名密钥（生产必须设置，不得为空）
JWT_ACCESS_SECRET=
# Refresh Token 加盐 pepper（生产必须设置）
REFRESH_TOKEN_PEPPER=
# IP 地址 hash pepper（生产必须设置）
IP_HASH_PEPPER=

# === Qoder Agent SDK ===
# Qoder 个人访问令牌（生产必须设置）
QODER_PERSONAL_ACCESS_TOKEN=
# Qoder 模型名称（可选，由 Qoder 环境决定）
QODER_MODEL=
# 聊天单轮超时（毫秒）
QODER_CHAT_TIMEOUT_MS=120000
# 知识清洗超时（毫秒）
QODER_CLEAN_TIMEOUT_MS=900000

# === IQS 搜索 ===
# IQS API 基础 URL（可选）
IQS_API_BASE_URL=
# IQS API 密钥（可选）
IQS_API_KEY=

# === Worker ===
# 知识清洗 Worker 并发数
KNOWLEDGE_WORKER_CONCURRENCY=1
# 任务租约时长（秒）
KNOWLEDGE_JOB_LEASE_SECONDS=300

# === 上传限制 ===
# 聊天图片最大字节数（默认 10MB）
UPLOAD_IMAGE_MAX_BYTES=10485760
# 知识文件最大字节数（默认 25MB）
UPLOAD_KNOWLEDGE_MAX_BYTES=26214400
# URL 抓取最大响应字节数（默认 5MB）
URL_FETCH_MAX_BYTES=5242880

# === 初始管理员（仅 bootstrap-admin.ts 脚本使用，生产首次启动后必须移除） ===
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_PASSWORD=

# === 日志与备份 ===
LOG_LEVEL=info
BACKUP_ROOT=/data/backups
