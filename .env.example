# === 运行环境 ===
# 应用运行环境 (development | test | production)
NODE_ENV=development
# 应用公网 URL
APP_BASE_URL=http://localhost:3000
# HTTP 监听端口
PORT=3000
# 时区
TZ=Asia/Shanghai

# === 数据路径 ===
# SQLite 数据库文件路径
DATABASE_PATH=/srv/iracing-ai-assistant/data/db/app.sqlite
# 持久化数据根目录
DATA_ROOT=/srv/iracing-ai-assistant/data
# Wiki Git worktree 路径
WIKI_ROOT=/srv/iracing-ai-assistant/data/md-wiki
# Web 知识源 Markdown 快照（可选，默认 notes/knowledge-sources.md）
WEB_KNOWLEDGE_SOURCES_SNAPSHOT_PATH=/srv/iracing-ai-assistant/data/knowledge-sources.md

# === Wiki Git ===
# Wiki Git 远程仓库地址（可选，未配置时仅本地提交）
WIKI_GIT_REMOTE=
# Wiki Git 分支
WIKI_GIT_BRANCH=main

# === 安全密钥 ===
# JWT Access Token 签名密钥（生产必须设置，不得为空）
JWT_ACCESS_SECRET=
# Refresh Token 加盐 pepper（生产必须设置）
REFRESH_TOKEN_PEPPER=
# IP 地址 hash pepper（生产必须设置）
IP_HASH_PEPPER=
# Refresh Cookie 是否仅通过 HTTPS 发送；生产保持 true，本地 HTTP/E2E 可设 false
REFRESH_COOKIE_SECURE=true

# === Qoder Agent SDK ===
# Qoder 个人访问令牌（生产必须设置）
QODER_PERSONAL_ACCESS_TOKEN=
# 聊天 Agent 模型（当前固定为 Qwen3.7-Plus）
QODER_MODEL=Qwen3.7-Plus
# 聊天单轮超时（毫秒）
QODER_CHAT_TIMEOUT_MS=120000
# Qoder Agent 长任务超时兼容配置
QODER_CLEAN_TIMEOUT_MS=900000

# === OpenAI 兼容 LLM API（知识清洗唯一后端）===
# 多个 provider 用逗号分隔，例如：longcat,openai-compatible
LLM_API_PROVIDERS=longcat
# LongCat OpenAI 兼容端点；实际请求会拼接 /v1/chat/completions
LONGCAT_API_BASE_URL=https://api.longcat.chat/openai
LONGCAT_API_KEY=
LONGCAT_MODEL=LongCat-2.0
# true: LongCat/LLM API 返回限流或额度不足时停止本轮清洗
STOP_ON_LLM_RATE_LIMIT=true
LLM_CLEAN_MAX_INPUT_CHARS=100000
# 知识清洗单次 LLM 生成的 token 上限（含思考+正文）。reasoning 模型会一并计入，过小会截断为空 content
LLM_CLEAN_MAX_TOKENS=16000

# === IQS 搜索 ===
# IQS API 基础 URL（可选）
IQS_API_BASE_URL=
# IQS API 密钥（可选）
IQS_API_KEY=

# === Worker ===
# 知识清洗 Worker 并发数
KNOWLEDGE_WORKER_CONCURRENCY=1
# 任务租约时长（秒）
KNOWLEDGE_JOB_LEASE_SECONDS=300

# === 上传限制 ===
# 聊天图片最大字节数（默认 10MB）
UPLOAD_IMAGE_MAX_BYTES=10485760
# 知识文件最大字节数（默认 25MB）
UPLOAD_KNOWLEDGE_MAX_BYTES=26214400
# URL 抓取最大响应字节数（默认 5MB）
URL_FETCH_MAX_BYTES=5242880

# === 初始管理员（仅 bootstrap-admin.ts 脚本使用，生产首次启动后必须移除） ===
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_PASSWORD=

# === 日志与备份 ===
LOG_LEVEL=info
BACKUP_ROOT=/srv/iracing-ai-assistant/data/backups

# === Chat eval（仅 scripts/eval-chat.ts，使用目标服务真实知识管理员 Token）===
# 不要提交真实值；HTTP eval 会通过目标服务 RBAC 校验此 Token。
EVAL_ADMIN_TOKEN=
